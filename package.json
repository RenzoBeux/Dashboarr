{
  "name": "dashboarr",
  "version": "1.10.4",
  "main": "expo-router/entry",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start:dev": "node scripts/run-dev.js start",
    "android:dev": "node scripts/run-dev.js run:android",
    "ios:dev": "node scripts/run-dev.js run:ios",
    "lint": "eslint .",
    "prebuild": "expo prebuild",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "bump:patch": "pnpm version patch -m \"chore: release v%s\"",
    "bump:minor": "pnpm version minor -m \"chore: release v%s\"",
    "bump:major": "pnpm version major -m \"chore: release v%s\"",
    "build:android:prod": "node scripts/build-android-prod.js",
    "release:android:apk": "node scripts/release-android-apk.js",
    "release:android:play": "eas submit --platform android --profile production --path android/app/build/outputs/bundle/release/app-release.aab --non-interactive",
    "release:android": "pnpm build:android:prod && pnpm release:android:apk && pnpm release:android:play",
    "build:ios:prod": "node scripts/release-ios.js --no-upload",
    "release:ios": "node scripts/release-ios.js"
  },
  "dependencies": {
    "@callstack/liquid-glass": "^0.7.1",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@tanstack/react-query": "^5.67.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "54",
    "expo-application": "~7.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-image": "^3.0.11",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "^55.0.18",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.11",
    "fast-xml-parser": "^5.8.0",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.1.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.21.7",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-sortables": "^1.9.4",
    "react-native-svg": "15.12.1",
    "react-native-udp": "^4.1.7",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/react": "~19.1.10",
    "canvas": "^3.2.3",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "prettier": "^3.4.0",
    "react-native-svg-transformer": "^1.5.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "sharp"
    ]
  }
}
